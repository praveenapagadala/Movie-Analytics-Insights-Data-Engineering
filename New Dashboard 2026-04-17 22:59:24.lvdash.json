    {
      "name": "movies_per_genre",
      "displayName": "Movies Count per Genre",
      "queryLines": [
        "SELECT\n",
        "  genre,\n",
        "  COUNT(DISTINCT movieId) as movie_count\n",
        "FROM\n",
        "  movie_genre\n",
        "GROUP BY\n",
        "  genre\n",
        "ORDER BY\n",
        "  movie_count DESC"
      ],
      "catalog": "workspace",
      "schema": "default"
    },
    {
      "name": "high_ratings_by_genre",
      "displayName": "High Ratings Count by Genre",
      "queryLines": [
        "SELECT\n",
        "  mg.genre,\n",
        "  COUNT(DISTINCT kr.movieId) as high_rating_count\n",
        "FROM\n",
        "  kpi_avg_rating_per_movie kr\n",
        "    JOIN movie_genre mg\n",
        "      ON kr.movieId = mg.movieId\n",
        "WHERE\n",
        "  kr.avg_rating >= 4.0\n",
        "GROUP BY\n",
        "  mg.genre\n",
        "ORDER BY\n",
        "  high_rating_count DESC"
      ],
      "catalog": "workspace",
      "schema": "default"
    },
    {
      "name": "user_activity_segmentation",
      "displayName": "User Activity Segmentation",
      "queryLines": [
        "SELECT\n",
        "  'Total Users' as category,\n",
        "  COUNT(DISTINCT userId) as user_count,\n",
        "  1 as sort_order\n",
        "FROM\n",
        "  ratings_silver\n",
        "UNION ALL\n",
        "SELECT\n",
        "  'Active Users' as category,\n",
        "  COUNT(DISTINCT userId) as user_count,\n",
        "  2 as sort_order\n",
        "FROM\n",
        "  (\n",
        "    SELECT\n",
        "      userId,\n",
        "      COUNT(*) as cnt\n",
        "    FROM\n",
        "      ratings_silver\n",
        "    GROUP BY\n",
        "      userId\n",
        "    HAVING\n",
        "      COUNT(*) >= 10\n",
        "  )\n",
        "UNION ALL\n",
        "SELECT\n",
        "  'Highly Active Users' as category,\n",
        "  COUNT(DISTINCT userId) as user_count,\n",
        "  3 as sort_order\n",
        "FROM\n",
        "  (\n",
        "    SELECT\n",
        "      userId,\n",
        "      COUNT(*) as cnt\n",
        "    FROM\n",
        "      ratings_silver\n",
        "    GROUP BY\n",
        "      userId\n",
        "    HAVING\n",
        "      COUNT(*) >= 50\n",
        "  )"
      ],
      "catalog": "workspace",
      "schema": "default"
    },
